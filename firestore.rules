rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - description: string (optional)
    //   - status: string (required)
    //   - color: string (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - userId: string (required)
    //   - projectId: string (required)
    //   - projectName: string (optional)
    //   - projectColor: string (optional)
    //   - title: string (required)
    //   - priority: string (required)
    //   - status: string (required)
    //   - dueDate: timestamp (required)
    //   - reminder: string (optional)
    //   - assignee: string (optional)
    //   - notified: boolean (optional)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             (!( 'displayName' in data ) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!( 'photoURL' in data ) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!( 'createdAt' in data ) || data.createdAt is timestamp);
    }

    function isValidProject(data) {
      return hasRequiredFields(['userId', 'title', 'status', 'color']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.status is string && data.status.size() > 0 && data.status.size() < 50 &&
             data.color is string && data.color.size() > 0 && data.color.size() < 50 &&
             (!( 'description' in data ) || (data.description is string && data.description.size() < 1000)) &&
             (!( 'createdAt' in data ) || data.createdAt is timestamp);
    }

    function isValidTask(data) {
      return hasRequiredFields(['userId', 'projectId', 'title', 'priority', 'status', 'dueDate']) &&
             data.userId == request.auth.uid &&
             data.projectId is string && data.projectId.size() > 0 && data.projectId.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.priority is string && data.priority.size() > 0 && data.priority.size() < 50 &&
             data.status is string && data.status.size() > 0 && data.status.size() < 50 &&
             data.dueDate is timestamp &&
             (!( 'projectName' in data ) || (data.projectName is string && data.projectName.size() < 100)) &&
             (!( 'projectColor' in data ) || (data.projectColor is string && data.projectColor.size() < 50)) &&
             (!( 'reminder' in data ) || (data.reminder is string && data.reminder.size() < 50)) &&
             (!( 'assignee' in data ) || (data.assignee is string && data.assignee.size() < 100)) &&
             (!( 'notified' in data ) || data.notified is bool) &&
             (!( 'createdAt' in data ) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isRequestOwner() && isValidProject(request.resource.data);
      allow update: if isDocOwner() && uidNotModified() && isValidProject(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isRequestOwner() && isValidTask(request.resource.data);
      allow update: if isDocOwner() && uidNotModified() && isValidTask(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
